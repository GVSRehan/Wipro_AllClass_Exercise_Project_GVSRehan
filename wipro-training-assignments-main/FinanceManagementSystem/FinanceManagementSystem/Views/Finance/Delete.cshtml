@model Expense
@{
    ViewData["Title"] = "Delete Expense";
}

<h2 class="mb-3 text-danger">Delete Expense</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this expense?
</div>

<dl class="row">
    <dt class="col-sm-2">Amount</dt>
    <dd class="col-sm-10">@Model.Amount</dd>

    <dt class="col-sm-2">Category Id</dt>
    <dd class="col-sm-10">@Model.CategoryId</dd>

    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ExpenseId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

