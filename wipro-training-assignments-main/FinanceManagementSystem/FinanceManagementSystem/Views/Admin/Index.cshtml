@model IEnumerable<User>
@{
    ViewData["Title"] = "Admin - Users";
}

<div class="fm-card mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h2 class="h5 mb-0 text-white">All users</h2>
        <a class="btn btn-sm fm-btn-outline" asp-action="CategoryLeaders">View top spender per category</a>
    </div>

    @if (!Model.Any())
    {
        <p class="text-muted mb-0">No users found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="fm-report-table">
                <thead>
                    <tr>
                        <th>User Id</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.UserId</td>
                        <td>@u.Username</td>
                        <td>@u.Email</td>
                        <td class="text-nowrap">
                            <a class="btn btn-sm fm-btn-outline" asp-action="UserDetails" asp-route-id="@u.UserId">View summary</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

