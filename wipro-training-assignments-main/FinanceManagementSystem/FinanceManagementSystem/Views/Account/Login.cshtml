@{
    ViewData["Title"] = "Sign in";
    Layout = "_AccountLayout";
}

<div class="fm-auth-card">
    <h1 class="fm-auth-title">Sign in</h1>
    <p class="fm-auth-subtitle">Use your account to continue</p>

    @if (TempData["Message"] != null)
    {
        <div class="fm-auth-message">@TempData["Message"]</div>
    }

    <form asp-action="Login" method="post" class="fm-auth-form">
        <div asp-validation-summary="ModelOnly" class="fm-auth-error"></div>

        <div class="fm-auth-field">
            <label for="username" class="fm-auth-label">Username</label>
            <input id="username" name="username" class="fm-auth-input" type="text" placeholder="Enter username" autocomplete="username" />
        </div>

        <div class="fm-auth-field">
            <label for="password" class="fm-auth-label">Password</label>
            <input id="password" name="password" class="fm-auth-input" type="password" placeholder="Enter password" autocomplete="current-password" />
        </div>

        <button type="submit" class="fm-auth-submit">Sign in</button>

        <p class="fm-auth-switch">
            New user? <a asp-controller="Account" asp-action="Register" class="fm-auth-link">Create an account</a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
